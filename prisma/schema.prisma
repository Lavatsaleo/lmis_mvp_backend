generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  WAREHOUSE_OFFICER
  FACILITY_OFFICER
  CLINICIAN
  VIEWER
}

enum FacilityType {
  WAREHOUSE
  FACILITY
}

enum BoxStatus {
  CREATED
  IN_WAREHOUSE
  IN_TRANSIT
  IN_FACILITY
  DISPENSED
  VOID
}

enum BoxEventType {
  QR_CREATED
  WAREHOUSE_RECEIVE
  DISPATCH
  FACILITY_RECEIVE
  DISPENSE
  ADJUSTMENT
}

enum ShipmentStatus {
  DISPATCHED
  RECEIVED
  CANCELLED
}

//
// NEW: assessment type so we can store ENROLLMENT + DISCHARGE assessments per child
//
enum AssessmentType {
  ENROLLMENT
  DISCHARGE
}

model Facility {
  id   String       @id @default(cuid())
  code String       @unique
  name String
  type FacilityType @default(FACILITY)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // link a Facility to a Warehouse (warehouses are also Facility records)
  warehouseId String?
  warehouse   Facility?  @relation("WarehouseFacilities", fields: [warehouseId], references: [id])
  facilities  Facility[] @relation("WarehouseFacilities")

  // Users assigned to this facility
  users User[]

  // Boxes currently at this facility
  boxes Box[] @relation("currentFacility")

  // Facility-level history: events where this facility is the source
  outboundEvents BoxEvent[] @relation("fromFacility")

  // Facility-level history: events where this facility is the destination
  inboundEvents BoxEvent[] @relation("toFacility")

  // Shipments / Manifests
  outboundShipments Shipment[] @relation("ShipmentsFromWarehouse")
  inboundShipments  Shipment[] @relation("ShipmentsToFacility")

  // Clinical
  caregivers  Caregiver[]
  children    Child[]
  childVisits ChildVisit[]
  assessments InDepthAssessment[]

  @@index([warehouseId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String
  passwordHash String
  role         UserRole @default(VIEWER)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?

  facilityId String?
  facility   Facility? @relation(fields: [facilityId], references: [id])

  // Logistics events performed by this user
  boxEvents BoxEvent[] @relation("PerformedBoxEvents")

  // Clinical actions performed by this user
  childVisits ChildVisit[]        @relation("PerformedVisits")
  assessments InDepthAssessment[] @relation("PerformedAssessments")

  // Shipments / Manifests
  dispatchedShipments Shipment[] @relation("ShipmentsDispatchedBy")
  receivedShipments   Shipment[] @relation("ShipmentsReceivedBy")

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  shipmentItems ShipmentItem[]

  @@index([facilityId])
  @@index([role])
}

model Order {
  id          String   @id @default(cuid())
  orderNumber String   @unique
  donorName   String?
  createdAt   DateTime @default(now())

  boxes Box[]
}

model Product {
  id   String @id @default(cuid())
  code String @unique
  name String

  boxes Box[]
}

model Box {
  id         String    @id @default(cuid())
  boxUid     String    @unique
  orderId    String
  productId  String
  batchNo    String
  expiryDate DateTime
  status     BoxStatus @default(CREATED)
  createdAt  DateTime  @default(now())

  // --- Facility store tracking (each box contains sachets) ---
  // Default: 600 sachets per box
  sachetsPerBox    Int @default(600)
  // Remaining sachets in this box (decrements as clinicians dispense)
  sachetsRemaining Int @default(600)

  currentFacilityId String?
  currentFacility   Facility? @relation("currentFacility", fields: [currentFacilityId], references: [id])

  order   Order      @relation(fields: [orderId], references: [id])
  product Product    @relation(fields: [productId], references: [id])
  events  BoxEvent[]

  // Optional: link a dispensation record to this box (clinical)
  dispenses Dispense[]

  // Shipments / Manifests
  shipmentItems ShipmentItem[]

  @@index([orderId])
  @@index([productId])
  @@index([currentFacilityId])
  @@index([batchNo])
  @@index([expiryDate])
}

model BoxEvent {
  id                String       @id @default(cuid())
  boxId             String
  type              BoxEventType
  performedByUserId String
  fromFacilityId    String?
  toFacilityId      String?
  note              String?
  createdAt         DateTime     @default(now())

  box Box @relation(fields: [boxId], references: [id])

  performedBy User @relation("PerformedBoxEvents", fields: [performedByUserId], references: [id])

  fromFacility Facility? @relation("fromFacility", fields: [fromFacilityId], references: [id])
  toFacility   Facility? @relation("toFacility", fields: [toFacilityId], references: [id])

  @@index([boxId])
  @@index([performedByUserId])
  @@index([fromFacilityId])
  @@index([toFacilityId])
  @@index([type])
}

model Shipment {
  id         String         @id @default(cuid())
  manifestNo String         @unique
  status     ShipmentStatus @default(DISPATCHED)

  note String?

  fromWarehouseId String
  toFacilityId    String

  dispatchedByUserId String
  dispatchedAt       DateTime @default(now())

  receivedByUserId String?
  receivedAt       DateTime?

  // For idempotent dispatch retries
  idempotencyKey String? @unique

  fromWarehouse Facility @relation("ShipmentsFromWarehouse", fields: [fromWarehouseId], references: [id])
  toFacility    Facility @relation("ShipmentsToFacility", fields: [toFacilityId], references: [id])

  dispatchedBy User  @relation("ShipmentsDispatchedBy", fields: [dispatchedByUserId], references: [id])
  receivedBy   User? @relation("ShipmentsReceivedBy", fields: [receivedByUserId], references: [id])

  items ShipmentItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fromWarehouseId])
  @@index([toFacilityId])
  @@index([status])
  @@index([dispatchedAt])
}

model ShipmentItem {
  id         String @id @default(cuid())
  shipmentId String
  boxId      String

  receivedAt       DateTime?
  receivedByUserId String?

  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  box        Box      @relation(fields: [boxId], references: [id])
  receivedBy User?    @relation(fields: [receivedByUserId], references: [id])

  @@unique([shipmentId, boxId])
  @@index([shipmentId])
  @@index([boxId])
}

//
// -------------------- CLINICAL --------------------
//

model Caregiver {
  id         String  @id @default(cuid())
  facilityId String
  fullName   String
  contacts   String
  village    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id])
  children Child[]

  // Helps you handle duplicates well: same phone in the same facility should not create new caregiver
  @@unique([facilityId, contacts])
  @@index([facilityId])
  @@index([fullName])
}

model Child {
  id          String @id @default(cuid())
  facilityId  String
  caregiverId String

  // Program code (for now SQLNS, but keep as String for flexibility/MVP)
  program String @default("SQLNS")

  enrollmentDate DateTime @default(now())

  firstName   String
  lastName    String
  sex         String
  dateOfBirth DateTime
  cwcNumber   String

  // System-generated registration number (facilityCode/cwcNumber/program)
  uniqueChildNumber String @unique

  // Optional CHP details from registration form
  chpName     String?
  chpContacts String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facility  Facility  @relation(fields: [facilityId], references: [id])
  caregiver Caregiver @relation(fields: [caregiverId], references: [id])

  visits ChildVisit[]

  // NOW: can store ENROLLMENT + DISCHARGE assessments (and potentially more in future)
  inDepthAssessments InDepthAssessment[]

  @@unique([facilityId, cwcNumber])
  @@index([facilityId])
  @@index([caregiverId])
  @@index([lastName, firstName])
  @@index([cwcNumber])
  @@index([program])
}

model InDepthAssessment {
  id                String @id @default(cuid())
  childId           String
  facilityId        String
  performedByUserId String

  // NEW: to store ENROLLMENT + DISCHARGE per child
  assessmentType AssessmentType @default(ENROLLMENT)

  // When the assessment was done (default now, but you can set from form)
  assessmentDate DateTime @default(now())

  // Keep the whole form payload here (all answers + skip logic outputs)
  data Json

  // OPTIONAL: store a few key values for dashboards (fast queries)
  muacMm                  Int?
  weightKg                Float?
  heightCm                Float?
  householdHungerScore    Int?
  householdHungerCategory String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  child       Child    @relation(fields: [childId], references: [id])
  facility    Facility @relation(fields: [facilityId], references: [id])
  performedBy User     @relation("PerformedAssessments", fields: [performedByUserId], references: [id])

  // IMPORTANT: allows ONE enrollment + ONE discharge per child
  @@unique([childId, assessmentType])
  @@index([facilityId])
  @@index([performedByUserId])
  @@index([assessmentDate])
  @@index([assessmentType])
}

model ChildVisit {
  id                String @id @default(cuid())
  childId           String
  facilityId        String
  performedByUserId String

  visitDate DateTime
  notes     String?

  // NEW: Anthropometry captured during follow-up visits (and can be used for diary/attendance)
  weightKg Float?
  heightCm Float?
  muacMm   Int?
  whzScore Float?

  // NEW: Next appointment date stored ONLY in child visits
  nextAppointmentDate DateTime?

  createdAt DateTime @default(now())

  child       Child    @relation(fields: [childId], references: [id])
  facility    Facility @relation(fields: [facilityId], references: [id])
  performedBy User     @relation("PerformedVisits", fields: [performedByUserId], references: [id])

  dispenses Dispense[]

  @@index([childId])
  @@index([facilityId])
  @@index([performedByUserId])
  @@index([visitDate])
  @@index([nextAppointmentDate])
}

model Dispense {
  id              String  @id @default(cuid())
  visitId         String
  boxId           String? // optional if dispensing without scanning a box (future)
  quantitySachets Int
  note            String?

  createdAt DateTime @default(now())

  visit ChildVisit @relation(fields: [visitId], references: [id])

  // Link to box if scanned
  box Box? @relation(fields: [boxId], references: [id])

  @@index([visitId])
  @@index([boxId])
}
